[Unit]
Description=OnePercent rent_predictions_audit partition rotation (archive + drop >90d)
After=network-online.target oper-postgres.service
Requires=oper-postgres.service
OnFailure=oper-backup-failure.service

[Service]
Type=oneshot
Nice=10
IOSchedulingClass=idle
ExecStart=/opt/onepercent/ops/systemd/oper-audit-rotate.sh
MemoryMax=256M

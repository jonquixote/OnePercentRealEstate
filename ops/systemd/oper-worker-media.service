[Unit]
Description=OnePercent Media Health Worker
After=oper-postgres.service
Requires=oper-postgres.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/onepercent
EnvironmentFile=/etc/oper.env
EnvironmentFile=-/etc/oper-role-worker.env
ExecStart=/usr/bin/node apps/worker/dist/media-health.js
Restart=on-failure
RestartSec=5
MemoryMax=384M

[Install]
WantedBy=multi-user.target

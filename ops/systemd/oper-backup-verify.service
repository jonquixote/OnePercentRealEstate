[Unit]
Description=OnePercent Postgres backup restore-drill (weekly)
After=network-online.target oper-postgres.service
Requires=oper-postgres.service
OnFailure=oper-backup-failure.service

[Service]
Type=oneshot
Nice=10
IOSchedulingClass=idle
ExecStart=/opt/onepercent/ops/systemd/verify-backup.sh
MemoryMax=256M

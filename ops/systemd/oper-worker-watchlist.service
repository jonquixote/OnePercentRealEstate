[Unit]
Description=OnePercent Watchlist Alerts Worker
After=oper-postgres.service
Requires=oper-postgres.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/onepercent
EnvironmentFile=/etc/oper.env
EnvironmentFile=-/etc/oper-role-worker.env
ExecStart=/usr/bin/node apps/worker/dist/watchlist-alerts.js
Restart=on-failure
RestartSec=5
MemoryHigh=192M
MemoryMax=256M

[Install]
WantedBy=multi-user.target
